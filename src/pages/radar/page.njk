{% extends "common/layout.njk" %}
{% from "common/status-classifications.njk" import status_classifications %}

{% block title %}
  <title>Home | {{ serviceName }}</title>
{% endblock %}

{% block content %}
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-three-quarters">
        <h1 class="govuk-heading-l">AI Capabilities and Enablement (AICE) Technology Radar</h1>
        <p class="govuk-body-m">
          This is a visual guide to the AI tools, frameworks, techniques and platforms the AI Capabilities and Enablement (AICE) team are currently exploring.
        </p>
        <h2 class="govuk-heading-m">Who is this for?</h2>
        <p class="govuk-body-m govuk-!-margin-bottom-2">The intended audience of this radar is professions within Defra Digital Delivery who need to see the current state of AI tooling.
          This includes, but is not limited to:
        </p>
        <ul class="govuk-list govuk-list--bullet">
          <li>Software developers</li>
          <li>QA engineers and testers</li>
          <li>Business analysts</li>
          <li>Content designers</li>
          <li>Product and delivery managers</li>
          <li>User researchers</li>
        </ul>
      </div>
    </div>

    <h2 class="govuk-heading-m govuk-!-margin-top-8">Current radar</h2>

    <div class="govuk-grid-row govuk-!-margin-top-8 quadrant-row">
      <div class="govuk-grid-column-one-half radar-quadrant" data-align="left">
        <h2 class="govuk-heading-m"><a class="govuk-link" href="#">Tools</a></h2>
        <object class="radar-svg" id="radar-tools" type="image/svg+xml" data="{{ getAssetPath('assets/tech-radar/aice-tech-radar-tools.svg') }}">
          <img src="{{ getAssetPath('assets/tech-radar/aice-tech-radar-tools.png') }}" alt="Tools quadrant">
        </object>
      </div>

      <div class="govuk-grid-column-one-half radar-quadrant" data-align="right">
        <h2 class="govuk-heading-m"><a class="govuk-link" href="#">Frameworks</a></h2>
        <object class="radar-svg" id="radar-frameworks" type="image/svg+xml" data="{{ getAssetPath('assets/tech-radar/aice-tech-radar-frameworks.svg') }}">
          <img src="{{ getAssetPath('assets/tech-radar/aice-tech-radar-frameworks.png') }}" alt="Frameworks quadrant">
        </object>
      </div>
    </div>

    <div class="govuk-grid-row govuk-!-margin-top-2 radar-labels">
      <div class="govuk-grid-column-one-half">
        <div class="radar-ring-labels radar-ring-labels-left">
          <span class="govuk-body radar-ring-label">Do Not Use</span>
          <span class="govuk-body radar-ring-label">Assess</span>
          <span class="govuk-body radar-ring-label">Pilot</span>
          <span class="govuk-body radar-ring-label">Endorse</span>
        </div>
      </div>

      <div class="govuk-grid-column-one-half">
        <div class="radar-ring-labels radar-ring-labels-right">
          <span class="govuk-body radar-ring-label">Endorse</span>
          <span class="govuk-body radar-ring-label">Pilot</span>
          <span class="govuk-body radar-ring-label">Assess</span>
          <span class="govuk-body radar-ring-label">Do Not Use</span>
        </div>
      </div>
    </div>

    <div class="govuk-grid-row govuk-!-margin-top-2 quadrant-row">
      <div class="govuk-grid-column-one-half radar-quadrant" data-align="left">
        <object class="radar-svg" id="radar-techniques" type="image/svg+xml" data="{{ getAssetPath('assets/tech-radar/aice-tech-radar-techniques.svg') }}">
          <img src="{{ getAssetPath('assets/tech-radar/aice-tech-radar-techniques.png') }}" alt="Techniques quadrant">
        </object>
        <h2 class="govuk-heading-m"><a class="govuk-link" href="#">Techniques</a></h2>
      </div>

      <div class="govuk-grid-column-one-half radar-quadrant" data-align="right">
        <object class="radar-svg" id="radar-platforms" type="image/svg+xml" data="{{ getAssetPath('assets/tech-radar/aice-tech-radar-platforms.svg') }}">
          <img src="{{ getAssetPath('assets/tech-radar/aice-tech-radar-platforms.png') }}" alt="Platforms quadrant">
        </object>
        <h2 class="govuk-heading-m"><a class="govuk-link" href="#">Platforms</a></h2>
      </div>
    </div>

    <div class="govuk-grid-row govuk-!-margin-top-6">
      <div class="govuk-grid-column-two-thirds">
        {{ status_classifications() }}
      </div>
    </div>
    <div class="govuk-grid-row govuk-!-margin-top-2">
      <div class="govuk-grid-column-three-quarters">
        <h2 class="govuk-heading-m">Who owns this radar?</h2>
        <p class="govuk-body-m">
          This radar is owned and maintained by the AI Capabilities and Enablement (AICE) team.
          For any questions or feedback, contact the team via Slack <a class="govuk-link" href="{{ aceSlackChannel }}" target="_blank">#ask-ace</a>.
        </p>
      </div>
    </div>
    <div class="govuk-grid-row govuk-!-margin-top-2">
      <div class="govuk-grid-column-three-quarters">
        <h2 class="govuk-heading-m">How does this relate to the Defra Tools Radar?</h2>
        <p class="govuk-body-m">
          This radar complements the Defra Tools Radar by focusing on AI-specific tools and practices.
          We work alongside the Defra Tools Authority where appropriate, and entries from this radar may be added to the Defra Tools Radar.
        </p>
      </div>
    </div>
{% endblock %}
