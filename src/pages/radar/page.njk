{% extends "common/layout.njk" %}
{% from "common/status-classifications.njk" import status_classifications %}

{% block title %}
  <title>Home | {{ serviceName }}</title>
{% endblock %}

{% block content %}
  <div class="defra-hero">
    <div class="govuk-width-container">
      <h1 class="govuk-heading-xl">AI Capabilities and Enablement (AICE) Technology Radar</h1>
      <p class="govuk-body-l">
        This is a visual guide to the AI tools, frameworks, techniques and platforms the AI Capabilities and Enablement (AICE) team are currently exploring.
      </p>
    </div>
  </div>

  <div class="govuk-width-container">
    <div class="govuk-grid-row govuk-!-margin-top-6">
      <div class="govuk-grid-column-full">
        <div class="dfe-grid-container">
          <a href="/tools" class="dfe-card">
            <div class="dfe-card-container">
              <h3 class="govuk-heading-m">
                <span class="dfe-card-link--header">Tools</span>
              </h3>
              <p class="govuk-body">Explore tooling used for AI development and deployment.</p>
            </div>
          </a>

          <a href="/platforms" class="dfe-card">
            <div class="dfe-card-container">
              <h3 class="govuk-heading-m">
                <span class="dfe-card-link--header">Platforms</span>
              </h3>
              <p class="govuk-body">Browse platforms that host or provide AI services.</p>
            </div>
          </a>

          <a href="/techniques" class="dfe-card">
            <div class="dfe-card-container">
              <h3 class="govuk-heading-m">
                <span class="dfe-card-link--header">Techniques</span>
              </h3>
              <p class="govuk-body">Read about AI techniques and approaches.</p>
            </div>
          </a>

          <a href="/frameworks" class="dfe-card">
            <div class="dfe-card-container">
              <h3 class="govuk-heading-m">
                <span class="dfe-card-link--header">Frameworks</span>
              </h3>
              <p class="govuk-body">Find frameworks and libraries for building AI solutions.</p>
            </div>
          </a>
        </div>
      </div>
    </div>

    <div class="govuk-grid-row govuk-!-margin-top-6">
      <div class="govuk-grid-column-two-thirds">
        {{ status_classifications() }}
      </div>
    </div>

    <div class="govuk-grid-row govuk-!-margin-top-2">
      <div class="govuk-grid-column-three-quarters">
        <h2 class="govuk-heading-m">Who is this for?</h2>
        <p class="govuk-body-m govuk-!-margin-bottom-2">The intended audience of this radar is professions within Defra Digital Delivery who need to see the current state of AI tooling. This includes, but is not limited to:</p>
        <ul class="govuk-list govuk-list--bullet">
          <li>Software developers</li>
          <li>QA engineers and testers</li>
          <li>Business analysts</li>
          <li>Content designers</li>
          <li>Product and delivery managers</li>
          <li>User researchers</li>
        </ul>
      </div>
    </div>

    <div class="govuk-grid-row govuk-!-margin-top-2">
      <div class="govuk-grid-column-three-quarters">
        <h2 class="govuk-heading-m">Who owns this radar?</h2>
        <p class="govuk-body-m">
          This radar is owned and maintained by the AI Capabilities and Enablement (AICE) team.
          For any questions or feedback, contact the team via Slack <a class="govuk-link" href="{{ aceSlackChannel }}" target="_blank">#ask-ace</a>.
        </p>
      </div>
    </div>

    <div class="govuk-grid-row govuk-!-margin-top-2">
      <div class="govuk-grid-column-three-quarters">
        <h2 class="govuk-heading-m">How does this relate to the Defra Tools Radar?</h2>
        <p class="govuk-body-m">
          This radar complements the Defra Tools Radar by focusing on AI-specific tools and practices.
          We work alongside the Defra Tools Authority where appropriate, and entries from this radar may be added to the Defra Tools Radar.
        </p>
      </div>
    </div>
  </div>
{% endblock %}
