{% extends "common/layout.njk" %}
{% from "common/status-classifications.njk" import status_classifications, ring_tag %}
{% from "common/radar-entries.njk" import radar_entries, radar_ring_labels %}

{% block title %}
  <title>Tools | {{ serviceName }}</title>
{% endblock %}

{% set page = 'tools' %}
{% set pageTitle = 'Tools' %}
{% set breadcrumbs = [
  { text: 'Home', href: '/' },
  { text: 'Tools' }
] %}

{% block content %}
  <div class="govuk-width-container">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-two-thirds">
        <h1 class="govuk-heading-l">Tools</h1>
      </div>
    </div>
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-one-half radar-quadrant radar-quadrant--sticky">
        <object class="radar-svg" id="radar-tools" type="image/svg+xml" data="{{ getAssetPath('images/aice-tech-radar-tools.svg') }}">
          <img src="{{ getAssetPath('images/aice-tech-radar-tools.png') }}" alt="Tools quadrant">
        </object>
        {{ radar_ring_labels('reversed') }}
        {{ status_classifications() }}
      </div>
      <div class="govuk-grid-column-one-half">
        {{ radar_entries(model.rings) }}
      </div>
    </div>
  </div>
{% endblock %}
